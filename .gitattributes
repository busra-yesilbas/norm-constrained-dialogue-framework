# GitHub Linguist configuration
# radar_chart.html is a 4.7 MB Plotly-generated output file, not source code.
# Vendoring it lets Python dominate correctly.

# Generated output — exclude from language stats
results/**/*.html   linguist-vendored=true

# Non-source files — exclude from language stats
*.md                linguist-documentation=true
docs/*.md           linguist-documentation=true
configs/*.yaml      linguist-documentation=true
*.txt               linguist-documentation=true
