# ============================================================
# Norm-Constrained Dialogue Framework — Environment Variables
# Copy this file to .env and fill in values as needed.
# The project runs fully in fallback (template) mode without
# any API keys set.
# ============================================================

# --- LLM Backend (optional) ---------------------------------
# Set to "openai", "azure", or leave blank for fallback mode
LLM_BACKEND=

# OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI (alternative)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# --- Experiment Settings ------------------------------------
RANDOM_SEED=42
LOG_LEVEL=INFO

# --- Output Paths -------------------------------------------
RESULTS_DIR=results
DATA_DIR=data/synthetic
